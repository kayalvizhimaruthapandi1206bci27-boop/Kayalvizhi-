#include <stdio.h>

int main() {
    int i, j, n = 5;

    // Outer loop iterate over each row
    for(i = 1; i <= n; i++) {
        
        // This inner loop prints spaces
        for(j = 1; j <= n - i; j++) {
            printf(" ");
        }
        // This inner loop prints stars in pyramid shape
        for(j = 1; j <= 2*i - 1; j++) {
            printf("*");
        }
        printf("\n");
    }

    return 0;
}

#include <stdio.h>

int main() {
    
    // Array to hold letters
    char alphabets[26]; 

    for (int i = 0; i < 26; i++) {
        
        // Store letters A-Z
        alphabets[i] = 'A' + i; 
    }

    // Print stored alphabets
    for (int i = 0; i < 26; i++) {
        printf("%c ", alphabets[i]);
    }
    return 0;
}
